<!-- JavaScript для добавления полей -->
<script>
function setHTML(element, html) {
    if (element.innerHTML !== undefined) {
        element.innerHTML = html;
    } else {
        var range = document.createRange();
        range.selectNodeContents(element);
        range.deleteContents();
        var fragment = range.createContextualFragment(html);
        element.appendChild(fragment);
    }
}

function addElement() {
    var table = document.getElementById('elementsTable');
    var tbody = document.getElementById('elementsBody');
    var rowCount = tbody.rows.length;
    var newRow = tbody.insertRow(rowCount);
    newRow.className = 'element-row';
    
    // Ячейка с номером
    var cellIndex = newRow.insertCell(0);
    cellIndex.className = 'element-index';
    setHTML(cellIndex, rowCount);
    
    // Ячейка с полем ввода
    var cellInput = newRow.insertCell(1);
    var inputHtml = '<input type="text" name="element' + rowCount + '" placeholder="Введите число" required>';
    setHTML(cellInput, inputHtml);
    
    // Обновляем скрытое поле
    document.getElementById('arrLength').value = rowCount + 1;
}
</script>

